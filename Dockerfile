FROM node:22-bookworm-slim

WORKDIR /app

COPY package*.json ./
RUN npm ci --omit=dev

COPY src ./src
COPY docker-entrypoint.sh ./docker-entrypoint.sh

RUN chmod +x ./docker-entrypoint.sh

ENV NODE_ENV=production
ENV HASH256_RPC_URL=wss://ethereum-rpc.publicnode.com
ENV HASH256_SUBMIT_RPC_URL=https://rpc.flashbots.net/fast
ENV HASH256_BATCH_SIZE=10000000
ENV HASH256_WORKERS=4
ENV HASH256_BOOST_WORKERS=0
ENV HASH256_BOOST_AFTER_MS=10000
ENV HASH256_WORKER_PROGRESS_EVERY=100000
ENV HASH256_POLL_INTERVAL_MS=2000
ENV HASH256_SPEEDUP_INTERVAL_MS=3000
ENV HASH256_WAIT_RECEIPT=0
ENV HASH256_EPOCH_WATCH_INTERVAL_MS=4000
ENV HASH256_MAX_PENDING_SUBMISSIONS=1
ENV HASH256_KEEP_MINING=1
ENV HASH256_ONCE=0
ENV HASH256_GAS_LIMIT=250000
ENV HASH256_GAS_BUFFER_PERCENTAGE=25
ENV HASH256_MAX_PRIORITY_FEE_GWEI=2
ENV HASH256_MAX_FEE_MULTIPLIER=2
ENV HASH256_MAX_TX_COST_USD=5
ENV MAX_GAS_BUDGET_USD=5
ENV PRIORITY_BOOST_PERCENTAGE=20

ENTRYPOINT ["./docker-entrypoint.sh"]
CMD ["mine"]
